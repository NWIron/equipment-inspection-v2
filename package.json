{
	"name": "equipment-inspection-v2",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "npm run build && wrangler pages dev",
		"db:init:local": "wrangler d1 execute equipment_inspection_v2 --local --file=./database/001_init.sql",
		"db:init:remote": "wrangler d1 execute equipment_inspection_v2 --remote --file=./database/001_init.sql",
		"format": "prettier --write --experimental-cli src/",
		"deploy": "npm run build && wrangler pages deploy",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"pinia": "^3.0.4",
		"vue": "^3.5.32",
		"vue-router": "^5.0.4"
	},
	"devDependencies": {
		"@vitejs/plugin-vue": "^6.0.7",
		"prettier": "3.8.3",
		"vite": "^7.3.1",
		"vite-plugin-vue-devtools": "^8.1.2",
		"wrangler": "^4.94.0"
	},
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	}
}